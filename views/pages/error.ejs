<section class="section" style="padding-top: 150px; min-height: 100vh; background: #0a0b0b; display: flex; align-items: center; justify-content: center;">
    <div class="section-bg fill"></div>
    <div class="section-content relative">
        <div class="row align-center">
            <div class="col small-12 large-12">
                <div class="col-inner text-center">
                    <div style="max-width: 500px; margin: 0 auto; padding: 40px;">
                        <div style="font-size: 100px; margin-bottom: 20px;">😕</div>
                        <h1 style="font-size: 2.5rem; font-weight: 700; color: #fff; margin-bottom: 20px;">
                            <%= typeof title !== 'undefined' ? title : 'Lỗi' %>
                        </h1>
                        <p style="font-size: 1.1rem; color: #888; margin-bottom: 30px;">
                            <%= typeof message !== 'undefined' ? message : 'Có lỗi xảy ra!' %>
                        </p>
                        <a href="/" class="button primary" style="background: #22c55e; color: #000; padding: 15px 40px; border-radius: 8px; text-decoration: none; font-weight: 600; display: inline-block;">
                            Quay lại trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



