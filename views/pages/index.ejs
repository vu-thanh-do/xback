                                        <script>
                                            document.addEventListener('DOMContentLoaded', function () {
                                                const trigger = document.getElementById('bizgpt-select-trigger');
                                                const options = document.getElementById('bizgpt-options');
                                                const selectedText = document.getElementById('bizgpt-selected-text');
                                                const searchInput = document.getElementById('bizgpt-search-input');
                                                const optionsList = document.getElementById('bizgpt-options-list');
                                                const noResults = document.getElementById('bizgpt-no-results');
                                                const btn = document.getElementById('bizgpt-scroll-btn');
                                                let currentValue = 'binance';

                                                const links = {
                                                    binance: 'huong-dan-dang-ki-san-binance/',
                                                    okx: 'huong-dan-dang-ky-san-okx/',
                                                    bingx: 'huong-dan-dang-ky-san-bingx/',
                                                    bybit: 'huong-dan-dang-ky-san-bybit/',
                                                    bitget: 'huong-dan-dang-ky-san-bitget/',
                                                    mexc: 'huong-dan-dang-ky-san-mexc/',
                                                    gateio: 'huong-dan-dang-ky-san-gate-io/',
                                                    kucoin: 'huong-dan-dang-ky-san-kucoin/',
                                                    exness: 'huong-dan-dang-ky-san-exness/',
                                                    private: 'huong-dan-tham-gia-vao-nhom-private-xBack Capital/',
                                                    lbank: '#'
                                                };

                                                // Toggle dropdown
                                                trigger.addEventListener('click', function (e) {
                                                    e.stopPropagation();
                                                    trigger.classList.toggle('active');
                                                    options.classList.toggle('active');
                                                    if (options.classList.contains('active')) {
                                                        searchInput.focus();
                                                    }
                                                });

                                                // Search functionality
                                                searchInput.addEventListener('input', function (e) {
                                                    const searchTerm = e.target.value.toLowerCase().trim();
                                                    const allOptions = optionsList.querySelectorAll('.bizgpt-option');
                                                    let hasVisibleOption = false;

                                                    allOptions.forEach(function (option) {
                                                        const text = option.textContent.toLowerCase();
                                                        if (text.includes(searchTerm)) {
                                                            option.classList.remove('hidden');
                                                            hasVisibleOption = true;
                                                        } else {
                                                            option.classList.add('hidden');
                                                        }
                                                    });

                                                    // Show/hide no results message
                                                    if (hasVisibleOption) {
                                                        noResults.classList.remove('active');
                                                    } else {
                                                        noResults.classList.add('active');
                                                    }
                                                });

                                                // Prevent dropdown from closing when clicking search input
                                                searchInput.addEventListener('click', function (e) {
                                                    e.stopPropagation();
                                                });

                                                // Select option
                                                optionsList.addEventListener('click', function (e) {
                                                    const option = e.target.closest('.bizgpt-option');
                                                    if (option && !option.classList.contains('hidden')) {
                                                        const value = option.getAttribute('data-value');
                                                        const text = option.textContent;

                                                        // Update selected
                                                        optionsList.querySelectorAll('.bizgpt-option').forEach(opt => opt.classList.remove('selected'));
                                                        option.classList.add('selected');

                                                        // Update display
                                                        selectedText.textContent = text;
                                                        currentValue = value;

                                                        // Reset search
                                                        searchInput.value = '';
                                                        optionsList.querySelectorAll('.bizgpt-option').forEach(opt => opt.classList.remove('hidden'));
                                                        noResults.classList.remove('active');

                                                        // Close dropdown
                                                        trigger.classList.remove('active');
                                                        options.classList.remove('active');
                                                    }
                                                });

                                                // Close dropdown when clicking outside
                                                document.addEventListener('click', function () {
                                                    trigger.classList.remove('active');
                                                    options.classList.remove('active');
                                                    // Reset search when closing
                                                    searchInput.value = '';
                                                    optionsList.querySelectorAll('.bizgpt-option').forEach(opt => opt.classList.remove('hidden'));
                                                    noResults.classList.remove('active');
                                                });

