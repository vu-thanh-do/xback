                                                <script>
                                                    jQuery(document).ready(function ($) {
                                                        const isLoggedIn = false;
                                                        const currentUser = {
                                                            username: '',
                                                            email: '',
                                                            telegram: ''
                                                        };
                                                        const API_KEY = "da4a8102-0e72-4d76-b8cf-26c113ee9138";
                                                        const USE_PROXY = true; // Đổi sang true để dùng proxy tránh CORS
                                                        let countdownInterval = null;

                                                        function showLoading(show, withCountdown = false) {
                                                            const overlay = document.getElementById('loading-overlay');
                                                            const loadingText = document.getElementById('loading-text');

                                                            if (show) {
                                                                overlay.classList.add('active');

                                                                if (withCountdown) {
                                                                    let seconds = 5;
                                                                    loadingText.textContent = `Đang kiểm tra... (${seconds}s)`;

                                                                    countdownInterval = setInterval(function () {
                                                                        seconds--;
                                                                        if (seconds > 0) {
                                                                            loadingText.textContent = `Đang kiểm tra... (${seconds}s)`;
                                                                        } else {
                                                                            loadingText.textContent = 'Đang xử lý dữ liệu...';
                                                                            clearInterval(countdownInterval);
                                                                        }
                                                                    }, 1000);
                                                                } else {
                                                                    loadingText.textContent = 'Đang kiểm tra...';
                                                                }
                                                            } else {
                                                                overlay.classList.remove('active');
                                                                if (countdownInterval) {
                                                                    clearInterval(countdownInterval);
                                                                    countdownInterval = null;
                                                                }
                                                                loadingText.textContent = 'Đang kiểm tra...';
                                                            }
                                                        }

                                                        function showError(message) {
                                                            document.getElementById('error-message').textContent = message;
                                                            document.getElementById('error-popup').classList.add('active');
                                                        }

                                                        window.closeErrorPopup = function () {
                                                            document.getElementById('error-popup').classList.remove('active');
                                                        }

                                                        // Đóng popup khi click overlay
                                                        document.getElementById('error-popup').addEventListener('click', function (e) {
                                                            if (e.target === this) {
                                                                closeErrorPopup();
                                                            }
                                                        });

                                                        function saveLog(data, exchange, uid) {
                                                            if (!isLoggedIn || !currentUser.username) {
                                                                console.warn('⚠️ User chưa đăng nhập, không lưu log');
                                                                return;
                                                            }

                                                            const logData = {
                                                                action: 'save_check_log',
                                                                nonce: '3da9c335be',
                                                                username: currentUser.username,
                                                                email: currentUser.email,
                                                                telegram: currentUser.telegram,
                                                                platform: exchange,
                                                                uid: uid,
                                                                vol: data.volume || data.trading_volume || '',
                                                                commission: data.rebate || data.commission || ''
                                                            };

                                                            console.log('📤 Đang lưu log:', logData);

                                                            $.ajax({
                                                                url: 'wp-admin/admin-ajax.php',
                                                                method: 'POST',
                                                                data: logData,
                                                                success: function (response) {
                                                                    console.log('✅ Log đã lưu:', response);

                                                                    if (response.success) {
                                                                        console.log('✅ Action:', response.data.action); // 'inserted' hoặc 'updated'
                                                                    } else {
                                                                        console.error('❌ Lỗi lưu log:', response.data);
                                                                    }
                                                                },
                                                                error: function (xhr, status, error) {
                                                                    console.error('❌ AJAX lỗi:', {
                                                                        status: status,
                                                                        error: error,
                                                                        response: xhr.responseText
                                                                    });
                                                                }
                                                            });
                                                        }

                                                        function normalizeResponse(resp) {
                                                            if (!resp) return { success: false };

                                                            // ✅ XỬ LÝ FORMAT MỚI: { "success": true, "data": {...} }
                                                            if (resp.success === true && resp.data) {
                                                                const d = resp.data;
                                                                return {
                                                                    success: true,
                                                                    data: {
                                                                        rebate: d.rebate !== null && d.rebate !== undefined ? d.rebate : '0',
                                                                        volume: d.volume !== null && d.volume !== undefined ? d.volume : '0',
                                                                        uid: d.uid ?? $('#uid').val().trim(),
                                                                        exchange: d.exchange ?? $('#exchange').val()
                                                                    }
                                                                };
                                                            }

                                                            // Kiểm tra response có data object (format cũ)
                                                            if (resp.data) {
                                                                const d = resp.data;
                                                                return {
                                                                    success: true,
                                                                    data: {
                                                                        rebate: d.commission ?? d.rebate ?? d.total_assets ?? '0',
                                                                        volume: d.volume ?? d.trading_volume ?? '0',
                                                                        uid: d.uid ?? $('#uid').val().trim(),
                                                                        exchange: d.market ?? d.exchange ?? $('#exchange').val()
                                                                    }
                                                                };
                                                            }

                                                            // Kiểm tra response level cao nhất (format cũ)
                                                            if (resp.commission || resp.volume || resp.rebate || resp.trading_volume || resp.total_assets) {
                                                                return {
                                                                    success: true,
                                                                    data: {
                                                                        rebate: resp.commission ?? resp.rebate ?? resp.total_assets ?? '0',
                                                                        volume: resp.volume ?? resp.trading_volume ?? '0',
                                                                        uid: resp.uid ?? $('#uid').val().trim(),
                                                                        exchange: resp.market ?? resp.exchange ?? $('#exchange').val()
                                                                    }
                                                                };
                                                            }

                                                            return { success: false };
                                                        }

                                                        // ✅ HÀM HIỂN THỊ KẾT QUẢ - CHỈ LƯU LOG KHI CÓ DỮ LIỆU HỢP LẼ
                                                        function displayResult(data, exchange, uid) {
                                                            console.log('📊 Display data:', data);

                                                            // Gán vào input (định dạng tiền tệ USD)
                                                            if (data.rebate !== undefined && data.rebate !== null) {
                                                                const rebateFormatted = Number(data.rebate).toLocaleString('en-US', {
                                                                    style: 'currency',
                                                                    currency: 'USD',
                                                                    minimumFractionDigits: 2
                                                                });
                                                                $('#rebate_month').val(rebateFormatted);
                                                            } else {
                                                                $('#rebate_month').val('$0.00');
                                                            }

                                                            if (data.volume !== undefined && data.volume !== null) {
                                                                const volumeFormatted = Number(data.volume).toLocaleString('en-US', {
                                                                    style: 'currency',
                                                                    currency: 'USD',
                                                                    minimumFractionDigits: 2
                                                                });
                                                                $('#volume_month').val(volumeFormatted);
                                                            } else {
                                                                $('#volume_month').val('$0.00');
                                                            }

                                                            showLoading(false);

                                                            // ✅ CHỈ LƯU LOG KHI CÓ CẢ VOLUME VÀ REBATE HỢP LỆ
                                                            if (data.volume !== undefined && data.volume !== null &&
                                                                data.rebate !== undefined && data.rebate !== null) {
                                                                console.log('✅ Dữ liệu hợp lệ, đang lưu log...');
                                                                saveLog(data, exchange, uid);
                                                            } else {
                                                                console.warn('⚠️ Dữ liệu không đầy đủ, không lưu log:', {
                                                                    volume: data.volume,
                                                                    rebate: data.rebate
                                                                });
                                                            }
                                                        }

                                                        $('#trading-search-form').on('submit', function (e) {
                                                            e.preventDefault();
                                                            e.stopPropagation();

                                                            if (!isLoggedIn) {
                                                                $('.login-popup-overlay').fadeIn();
                                                                return;
                                                            }

                                                            const exchange = $('#exchange').val();
                                                            const uid = $('#uid').val().trim();

                                                            if (!exchange || !uid) {
                                                                showError('Vui lòng chọn sàn và nhập UID.');
                                                                return;
                                                            }

                                                            showLoading(true, true);

                                                            // ⏱️ DELAY 5 GIÂY TRƯỚC KHI GỬI REQUEST
                                                            setTimeout(function () {
                                                                sendRequest(exchange, uid);
                                                            }, 5000);
                                                        });

                                                        // ✅ HÀM GỬI REQUEST (tách riêng để dễ quản lý)
                                                        function sendRequest(exchange, uid) {
                                                            if (USE_PROXY) {
                                                                // ✅ Sử dụng WordPress AJAX proxy
                                                                $.ajax({
                                                                    url: 'wp-admin/admin-ajax.php',
                                                                    method: 'POST',
                                                                    data: {
                                                                        action: 'fetch_trading_data',
                                                                        exchange: exchange,
                                                                        uid: uid,
                                                                        nonce: '723cfdcd23'
                                                                    },
                                                                    timeout: 30000,
                                                                    success: function (response) {
                                                                        console.log("✅ Proxy response:", response);

                                                                        if (response.success && response.data) {
                                                                            // ✅ displayResult sẽ tự kiểm tra và gọi saveLog nếu hợp lệ
                                                                            displayResult(response.data, exchange, uid);
                                                                        } else {
                                                                            showLoading(false);

                                                                            // ✅ KIỂM TRA LỖI 402 - UID NOT WHITELISTED
                                                                            if (response.data && response.data.raw) {
                                                                                const rawData = response.data.raw;

                                                                                // Case 1: Code 402 trong raw
                                                                                if (rawData.code === 402) {
                                                                                    showError('UID này chưa đăng ký dưới xBack Capital');
                                                                                    return;
                                                                                }

                                                                                // Case 2: Detail chứa "not whitelisted"
                                                                                if (rawData.detail && rawData.detail.toLowerCase().includes('not whitelisted')) {
                                                                                    showError('UID này chưa đăng ký dưới xBack Capital');
                                                                                    return;
                                                                                }
                                                                            }

                                                                            // ✅ KIỂM TRA MESSAGE CÓ CHỨA HTTP 402
                                                                            if (response.data && response.data.message) {
                                                                                if (response.data.message.includes('HTTP 402')) {
                                                                                    showError('UID này chưa đăng ký dưới xBack Capital');
                                                                                    return;
                                                                                }
                                                                            }

                                                                            showError('Hệ thống đang quá tải, bạn vui lòng kiểm tra lại sau nhé');
                                                                        }
                                                                    },
                                                                    error: function (xhr, status, err) {
                                                                        showLoading(false);
                                                                        console.error("❌ Proxy error:", status, err, xhr);

                                                                        let errorMsg = 'Lỗi khi kết nối API qua proxy.';
                                                                        if (status === 'timeout') {
                                                                            errorMsg = 'Timeout: API phản hồi quá chậm. Vui lòng thử lại sau.';
                                                                        }

                                                                        showError(errorMsg);
                                                                    }
                                                                });
                                                            } else {
                                                                // Gọi trực tiếp API
                                                                const url = `https://api.taphoa.dev/trade-info/${encodeURIComponent(exchange)}/${encodeURIComponent(uid)}`;

                                                                $.ajax({
                                                                    url: url,
                                                                    method: "GET",
                                                                    headers: {
                                                                        Accept: "application/json",
                                                                        "X-API-Key": API_KEY
                                                                    },
                                                                    timeout: 30000,
                                                                    crossDomain: true,
                                                                    cache: false,
                                                                    success: function (response) {
                                                                        console.log("✅ API raw response:", response);

                                                                        // ✅ Xử lý response theo format: {code: 200, msg: "Success", data: {...}}
                                                                        if (response.code === 200 && response.data) {
                                                                            const apiData = response.data;

                                                                            const normalized = {
                                                                                uid: apiData.uid,
                                                                                market: apiData.market,
                                                                                volume: apiData.trading_volume ?? null,
                                                                                rebate: apiData.commission ?? null,
                                                                                // Alias
                                                                                trading_volume: apiData.trading_volume ?? null,
                                                                                commission: apiData.commission ?? null,
                                                                                exchange: apiData.market
                                                                            };

                                                                            // ✅ displayResult sẽ tự kiểm tra và gọi saveLog nếu hợp lệ
                                                                            displayResult(normalized, exchange, uid);

                                                                        } else {
                                                                            showLoading(false);
                                                                            showError(response.msg || 'Không tìm thấy dữ liệu cho UID này.');
                                                                        }
                                                                    },
                                                                    error: function (xhr, status, err) {
                                                                        showLoading(false);
                                                                        console.error("❌ API error:", status, err, xhr);

                                                                        let errorMsg = 'Lỗi khi kết nối API.';
                                                                        if (status === 'timeout') {
                                                                            errorMsg = 'Timeout: API phản hồi quá chậm. Vui lòng thử lại.';
                                                                        } else if (xhr.status === 404) {
                                                                            errorMsg = 'UID không tồn tại hoặc không tìm thấy.';
                                                                        } else if (xhr.status === 401) {
                                                                            errorMsg = 'Lỗi xác thực API Key.';
                                                                        } else {
                                                                            errorMsg = 'UID is not whitelisted.';
                                                                        }
                                                                        showError(errorMsg);
                                                                    }
                                                                });
                                                            }
                                                        }

                                                        // Ngăn button click riêng lẻ
                                                        $('#check-volume').on('click', function (e) {
                                                            e.preventDefault();
                                                            $(this).closest('form').submit();
                                                        });

                                                        // Ẩn popup khi click bên ngoài
                                                        $(document).on('click', '.login-popup-overlay', function (e) {
                                                            if ($(e.target).is('.login-popup-overlay')) {
                                                                $(this).fadeOut();
                                                            }
                                                        });

                                                        function escapeHtml(text) {
                                                            if (!text && text !== 0) return '';
                                                            return String(text)
                                                                .replace(/&/g, "&amp;")
                                                                .replace(/</g, "&lt;")
                                                                .replace(/>/g, "&gt;")
                                                                .replace(/"/g, "&quot;")
                                                                .replace(/'/g, "&#039;");
                                                        }
                                                    });
                                                </script>


