                                                            e.stopPropagation();
                                                            const $dropdown = $(this).closest('.exchange-dropdown');

                                                            // Đóng các dropdown khác
                                                            $('.exchange-dropdown').not($dropdown).removeClass('active');

                                                            // Toggle dropdown hiện tại
                                                            $dropdown.toggleClass('active');
                                                        });

                                                        // Chọn item trong dropdown
                                                        $('.exchange-dropdown-item').on('click', function () {
                                                            const $this = $(this);
                                                            const value = $this.data('value');
                                                            const text = $this.text();
                                                            const $dropdown = $this.closest('.exchange-dropdown');
                                                            const $toggle = $dropdown.find('.exchange-dropdown-toggle');
                                                            const $hiddenInput = $dropdown.find('input[type="hidden"]');

                                                            // Cập nhật text của button (giữ lại icon)
                                                            const $arrow = $toggle.find('.exchange-dropdown-arrow');
                                                            $toggle.html(text + ' ').append($arrow);

                                                            // Cập nhật giá trị hidden input
                                                            if ($hiddenInput.length) {
                                                                $hiddenInput.val(value);
                                                            }

                                                            // Đóng dropdown
                                                            $dropdown.removeClass('active');
                                                        });

                                                        // Đóng dropdown khi click bên ngoài
                                                        $(document).on('click', function () {
                                                            $('.exchange-dropdown').removeClass('active');
                                                        });
                                                    });
                                                </script>

