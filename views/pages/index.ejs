                                    <script>
                                        jQuery(document).ready(function ($) {
                                            // ========== DROPDOWN ==========
                                            $('.exchange-dropdown-toggle-mb').on('click', function (e) {
                                                e.preventDefault();
                                                e.stopPropagation();
                                                const $dropdown = $(this).closest('.exchange-dropdown-mb');
                                                $('.exchange-dropdown-mb').not($dropdown).removeClass('active');
                                                $dropdown.toggleClass('active');
                                            });

                                            $('.exchange-dropdown-item-mb').on('click', function () {
                                                const $this = $(this);
                                                const value = $this.data('value');
                                                const text = $this.text();
                                                const $dropdown = $this.closest('.exchange-dropdown-mb');
                                                const $toggle = $dropdown.find('.exchange-dropdown-toggle-mb');
                                                const $hiddenInput = $dropdown.find('input[type="hidden"]');

                                                const $arrow = $toggle.find('.exchange-dropdown-arrow');
                                                $toggle.html(text + ' ').append($arrow);

                                                if ($hiddenInput.length) {
                                                    $hiddenInput.val(value);
                                                }

                                                $dropdown.removeClass('active');
                                            });

                                            $(document).on('click', function () {
                                                $('.exchange-dropdown-mb').removeClass('active');
                                            });

                                            // ========== CONFIG ==========
                                            const isLoggedIn = false;
                                            const currentUser = {
                                                username: '',
                                                email: '',
                                                telegram: ''
                                            };
                                            const USE_PROXY = true;
                                            let countdownInterval = null;

                                            // ========== LOADING ==========
                                            function showLoading(show, withCountdown = false) {
                                                const overlay = document.getElementById('loading-overlay-mb'); // ✅ ID đúng
                                                const loadingText = document.getElementById('loading-text-mb'); // ✅ ID đúng

                                                if (show) {
                                                    overlay.classList.add('active');

                                                    if (withCountdown) {
                                                        let seconds = 5;
                                                        loadingText.textContent = `Đang kiểm tra... (${seconds}s)`;
                                                        countdownInterval = setInterval(function () {
                                                            seconds--;
                                                            if (seconds > 0) {
                                                                loadingText.textContent = `Đang kiểm tra... (${seconds}s)`;
                                                            } else {
                                                                loadingText.textContent = 'Đang xử lý dữ liệu...';
                                                                clearInterval(countdownInterval);
                                                            }
                                                        }, 1000);
                                                    } else {
                                                        loadingText.textContent = 'Đang kiểm tra...';
                                                    }
                                                } else {
                                                    overlay.classList.remove('active');
                                                    if (countdownInterval) {
                                                        clearInterval(countdownInterval);
                                                        countdownInterval = null;
                                                    }
                                                    loadingText.textContent = 'Đang kiểm tra...';
                                                }
                                            }

                                            // ========== ERROR POPUP ==========
                                            function showError(message) {
                                                document.getElementById('error-message-mb').textContent = message; // ✅ ID đúng
                                                document.getElementById('error-popup-mb').classList.add('active'); // ✅ ID đúng
                                            }

                                            window.closeErrorPopupMb = function () {
                                                document.getElementById('error-popup-mb').classList.remove('active'); // ✅ ID đúng
                                            };

                                            document.getElementById('error-popup-mb').addEventListener('click', function (e) {
                                                if (e.target === this) {
                                                    closeErrorPopupMb();
                                                }
                                            });

                                            // ========== SAVE LOG ==========
                                            function saveLog(data, exchange, uid) {
                                                if (!isLoggedIn || !currentUser.username) {
                                                    console.warn('⚠️ User chưa đăng nhập, không lưu log');
                                                    return;
                                                }

                                                const logData = {
                                                    action: 'save_check_log',
                                                    nonce: '3da9c335be',
                                                    username: currentUser.username,
                                                    email: currentUser.email,
                                                    telegram: currentUser.telegram,
                                                    platform: exchange,
                                                    uid: uid,
                                                    vol: data.volume || data.trading_volume || '',
                                                    commission: data.rebate || data.commission || ''
                                                };

                                                console.log('📤 Đang lưu log:', logData);

                                                $.ajax({
                                                    url: 'wp-admin/admin-ajax.php',
                                                    method: 'POST',
                                                    data: logData,
                                                    success: function (response) {
                                                        console.log('✅ Log đã lưu:', response);
                                                        if (response.success) {
                                                            console.log('✅ Action:', response.data.action);
                                                        } else {
                                                            console.error('❌ Lỗi lưu log:', response.data);
                                                        }
                                                    },
                                                    error: function (xhr, status, error) {
                                                        console.error('❌ AJAX lỗi:', { status, error, response: xhr.responseText });
                                                    }
                                                });
                                            }

                                            // ========== DISPLAY RESULT ==========
                                            function displayResult(data, exchange, uid) {
                                                console.log('📊 Display data:', data);

                                                if (data.rebate !== undefined && data.rebate !== null) {
                                                    const rebateFormatted = Number(data.rebate).toLocaleString('en-US', {
                                                        style: 'currency', currency: 'USD', minimumFractionDigits: 2
                                                    });
                                                    $('#rebate_month-mb').val(rebateFormatted); // ✅ ID đúng
                                                } else {
                                                    $('#rebate_month-mb').val('$0.00');
                                                }

                                                if (data.volume !== undefined && data.volume !== null) {
                                                    const volumeFormatted = Number(data.volume).toLocaleString('en-US', {
                                                        style: 'currency', currency: 'USD', minimumFractionDigits: 2
                                                    });
                                                    $('#volume_month-mb').val(volumeFormatted); // ✅ ID đúng
                                                } else {
                                                    $('#volume_month-mb').val('$0.00');
                                                }

                                                showLoading(false);

                                                if (data.volume !== undefined && data.volume !== null &&
                                                    data.rebate !== undefined && data.rebate !== null) {
                                                    console.log('✅ Dữ liệu hợp lệ, đang lưu log...');
                                                    saveLog(data, exchange, uid);
                                                } else {
                                                    console.warn('⚠️ Dữ liệu không đầy đủ, không lưu log:', { volume: data.volume, rebate: data.rebate });
                                                }
                                            }

                                            // ========== SEND REQUEST ==========
                                            function sendRequest(exchange, uid) {
                                                if (USE_PROXY) {
                                                    $.ajax({
                                                        url: 'wp-admin/admin-ajax.php',
                                                        method: 'POST',
                                                        data: {
                                                            action: 'fetch_trading_data',
                                                            exchange: exchange,
                                                            uid: uid,
                                                            nonce: '723cfdcd23'
                                                        },
                                                        timeout: 30000,
                                                        success: function (response) {
                                                            console.log('✅ Proxy response:', response);

                                                            if (response.success && response.data) {
                                                                displayResult(response.data, exchange, uid);
                                                            } else {
                                                                showLoading(false);

                                                                if (response.data && response.data.raw) {
                                                                    const rawData = response.data.raw;
                                                                    if (rawData.code === 402) {
                                                                        showError('UID này chưa đăng ký dưới xBack Capital');
                                                                        return;
                                                                    }
                                                                    if (rawData.detail && rawData.detail.toLowerCase().includes('not whitelisted')) {
                                                                        showError('UID này chưa đăng ký dưới xBack Capital');
                                                                        return;
                                                                    }
                                                                }

                                                                if (response.data && response.data.message) {
                                                                    if (response.data.message.includes('HTTP 402')) {
                                                                        showError('UID này chưa đăng ký dưới xBack Capital');
                                                                        return;
                                                                    }
                                                                }

                                                                showError('Hệ thống đang quá tải, bạn vui lòng kiểm tra lại sau nhé');
                                                            }
                                                        },
                                                        error: function (xhr, status, err) {
                                                            showLoading(false);
                                                            console.error('❌ Proxy error:', status, err, xhr);

                                                            let errorMsg = 'Lỗi khi kết nối API qua proxy.';
                                                            if (status === 'timeout') {
                                                                errorMsg = 'Timeout: API phản hồi quá chậm. Vui lòng thử lại sau.';
                                                            }
                                                            showError(errorMsg);
                                                        }
                                                    });
                                                } else {
                                                    // Gọi trực tiếp API (không dùng proxy)
                                                    const API_KEY = "da4a8102-0e72-4d76-b8cf-26c113ee9138";
                                                    const url = `https://api.taphoa.dev/trade-info/${encodeURIComponent(exchange)}/${encodeURIComponent(uid)}`;

                                                    $.ajax({
                                                        url: url,
                                                        method: 'GET',
                                                        headers: {
                                                            Accept: 'application/json',
                                                            'X-API-Key': API_KEY
                                                        },
                                                        timeout: 30000,
                                                        crossDomain: true,
                                                        cache: false,
                                                        success: function (response) {
                                                            console.log('✅ API raw response:', response);

                                                            if (response.code === 200 && response.data) {
                                                                const apiData = response.data;
                                                                const normalized = {
                                                                    uid: apiData.uid,
                                                                    market: apiData.market,
                                                                    volume: apiData.trading_volume ?? null,
                                                                    rebate: apiData.commission ?? null,
                                                                    trading_volume: apiData.trading_volume ?? null,
                                                                    commission: apiData.commission ?? null,
                                                                    exchange: apiData.market
                                                                };
                                                                displayResult(normalized, exchange, uid);
                                                            } else {
                                                                showLoading(false);
                                                                showError(response.msg || 'Không tìm thấy dữ liệu cho UID này.');
                                                            }
                                                        },
                                                        error: function (xhr, status, err) {
                                                            showLoading(false);
                                                            console.error('❌ API error:', status, err, xhr);

                                                            let errorMsg = 'Lỗi khi kết nối API.';
                                                            if (status === 'timeout') {
                                                                errorMsg = 'Timeout: API phản hồi quá chậm. Vui lòng thử lại.';
                                                            } else if (xhr.status === 404) {
                                                                errorMsg = 'UID không tồn tại hoặc không tìm thấy.';
                                                            } else if (xhr.status === 401) {
                                                                errorMsg = 'Lỗi xác thực API Key.';
                                                            } else {
                                                                errorMsg = 'UID is not whitelisted.';
                                                            }
                                                            showError(errorMsg);
                                                        }
                                                    });
                                                }
                                            }

                                            // ========== FORM SUBMIT ==========
                                            $('#trading-search-form-mb').on('submit', function (e) { // ✅ ID đúng
                                                e.preventDefault();
                                                e.stopPropagation();

                                                if (!isLoggedIn) {
                                                    $('.login-popup-overlay-mb').fadeIn(); // ✅ class đúng
                                                    return;
                                                }

                                                const exchange = $('#exchange-mb').val(); // ✅ ID đúng
                                                const uid = $('#uid-mb').val().trim();    // ✅ ID đúng

                                                if (!exchange || !uid) {
                                                    showError('Vui lòng chọn sàn và nhập UID.');
                                                    return;
                                                }

                                                showLoading(true, true);

                                                // Delay 5 giây trước khi gửi request
                                                setTimeout(function () {
                                                    sendRequest(exchange, uid);
                                                }, 5000);
                                            });

                                            // Ngăn button click riêng lẻ
                                            $('#check-volume-mb').on('click', function (e) { // ✅ ID đúng
                                                e.preventDefault();
                                                $(this).closest('form').submit();
                                            });

                                            // Ẩn popup login khi click bên ngoài
                                            $(document).on('click', '.login-popup-overlay-mb', function (e) { // ✅ class đúng
                                                if ($(e.target).is('.login-popup-overlay-mb')) {
                                                    $(this).fadeOut();
                                                }
                                            });

                                            function escapeHtml(text) {
                                                if (!text && text !== 0) return '';
                                                return String(text)
                                                    .replace(/&/g, '&amp;')
                                                    .replace(/</g, '&lt;')
                                                    .replace(/>/g, '&gt;')
                                                    .replace(/"/g, '&quot;')
                                                    .replace(/'/g, '&#039;');
                                            }
                                        });
                                    </script>

