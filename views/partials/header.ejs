                                </li>
                                <li id="menu-item-about"
                                    class="menu-item menu-item-type-custom menu-item-object-custom <%= (typeof activePage !== 'undefined' && activePage === 'about') ? 'current-menu-item current_page_item active' : '' %> menu-item-14 menu-item-design-default">
