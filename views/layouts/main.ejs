    <script type="text/javascript" id="jquery-js-after">
        /* <![CDATA[ */
        jQuery(document).ready(function ($) {

            // Hàm hiển thị popup
            function showCopyPopup(code) {
                const popup = $('#copy-popup-global');
                popup.find('.copy-popup-code').text(code);
                popup.addClass('show');

                // Tự động tắt sau 2 giây
                setTimeout(function () {
                    popup.removeClass('show');
                }, 2000);
            }

            // Hàm copy text
            function copyToClipboard(text) {
                // Kiểm tra Clipboard API
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(function () {
                        showCopyPopup(text);
                    }).catch(function () {
                        fallbackCopyText(text);
                    });
                } else {
                    fallbackCopyText(text);
                }
            }

            // Phương pháp fallback cho trình duyệt cũ
            function fallbackCopyText(text) {
                const textArea = document.createElement('textarea');
                textArea.value = text;
                textArea.style.position = 'fixed';
                textArea.style.left = '-999999px';
                document.body.appendChild(textArea);
                textArea.select();

                try {
                    document.execCommand('copy');
                    showCopyPopup(text);
                } catch (err) {
                    alert('Không thể sao chép. Vui lòng copy thủ công: ' + text);
                }

                document.body.removeChild(textArea);
            }

            // Xử lý click vào text-code hoặc icon-code-copy
            $(document).on('click', '.stack-copy-code .text-code, .stack-copy-code .icon-code-copy', function () {
                // Tìm element chứa mã trong cùng stack
                const codeElement = $(this).closest('.stack-copy-code').find('.text-code p');

                if (codeElement.length) {
                    const code = codeElement.text().trim();

                    if (code) {
                        copyToClipboard(code);
                    } else {
                        alert('Không tìm thấy mã để copy!');
                    }
                }
            });
        });

        //# sourceURL=jquery-js-after
        /* ]]> */
    </script>
